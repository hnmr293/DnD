{
  "name": "dnd-mcp",
  "version": "0.2.0",
  "description": "MCP server for DnD .NET debugger — debug C# programs via MCP",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "dnd-mcp": "dist/index.js"
  },
  "files": [
    "dist/",
    "bin/"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "os": [
    "win32"
  ],
  "keywords": [
    "mcp",
    "debugger",
    "dotnet",
    "csharp",
    "model-context-protocol"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hnmr293/DnD.git",
    "directory": "mcp"
  },
  "homepage": "https://github.com/hnmr293/DnD#readme",
  "bugs": {
    "url": "https://github.com/hnmr293/DnD/issues"
  },
  "license": "Apache-2.0",
  "scripts": {
    "build": "tsc",
    "build:host": "dotnet publish ../debugger/src/DnD.Host/DnD.Host.csproj -c Release -o ./bin",
    "build:all": "npm run build:host && npm run build",
    "prepublishOnly": "npm run build:all",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "vscode-jsonrpc": "^8.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "typescript": "^5.9.3",
    "vitest": "^3.1.1"
  }
}
