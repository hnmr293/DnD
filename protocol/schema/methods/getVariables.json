{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "getVariables",
  "description": "Get variables for the given scope",
  "request": {
    "type": "object",
    "properties": {
      "frameId": { "type": ["integer", "null"], "description": "Stack frame ID (default: top frame)" }
    }
  },
  "response": {
    "type": "object",
    "properties": {
      "variables": {
        "type": "array",
        "items": { "$ref": "common.json#/definitions/Variable" }
      }
    },
    "required": ["variables"]
  }
}
